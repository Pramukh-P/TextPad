# MongoDB connection string (use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/TextPad_DB?retryWrites=true&w=majority

# Brevo API key (xkeysib-...) — from brevo.com → Settings → SMTP & API → API Keys tab
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Brevo account email (used as the sender address)
BREVO_SENDER_EMAIL=your-gmail@gmail.com

# Frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-textpad.vercel.app

# Port (Render sets this automatically)
PORT=5000
